{
  "name": "banana-lucky-nuxt",
  "type": "module",
  "private": true,
  "sideEffects": [
    "**/*.css",
    "**/*.scss",
    "**/*.vue",
    "**/plugins/**",
    "**/middleware/**"
  ],
  "engines": {
    "node": ">=20.11"
  },
  "scripts": {
    "prebuild": "rimraf .output --impl=move-remove",
    "build": "nuxt build",
    "dev": "nuxt dev",
    "start": "node .output/server/index.mjs",
    "generate": "nuxt generate",
    "typecheck": "nuxt typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "postinstall": "nuxt prepare",
    "test:component": "vitest run --project component",
    "test:all": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:perf": "playwright test network-device-load",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug"
  },
  "dependencies": {
    "@nuxt/fonts": "^0.13.0",
    "@nuxtjs/i18n": "^10.2.3",
    "@pinia/nuxt": "^0.11.3",
    "@sentry/nuxt": "^10.56.0",
    "@tailwindcss/vite": "^4.1.18",
    "@vee-validate/nuxt": "^4.15.1",
    "@vee-validate/zod": "^4.15.1",
    "axios": "^1.13.4",
    "dompurify": "^3.3.2",
    "httpxy": "^0.5.3",
    "ioredis": "^5.10.1",
    "nuxt": "^4.3.0",
    "nuxt-security": "^2.5.1",
    "tailwindcss": "^4.1.18",
    "vee-validate": "^4.15.1",
    "vue": "^3.5.27",
    "vue-router": "^4.6.4",
    "vue-sonner": "^2.0.9",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@nuxt/eslint": "^1.15.2",
    "@nuxt/image": "^2.0.0",
    "@nuxt/test-utils": "^4.0.3",
    "@pinia/testing": "^1.0.3",
    "@playwright/test": "^1.58.2",
    "@types/node": "^22.10.0",
    "@vite-pwa/nuxt": "^1.1.1",
    "@vitest/coverage-v8": "^4.1.8",
    "@vue/test-utils": "^2.4.11",
    "happy-dom": "^20.10.2",
    "rimraf": "^6.1.3",
    "vitest": "^4.1.8"
  }
}

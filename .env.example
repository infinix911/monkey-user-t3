# =============================================================================
# banana-lucky-nuxt — Environment Variables
# Copy this file to .env and fill in the values for your environment.
# =============================================================================

# Brand identifier — REQUIRED. One of:
#   lucky | ocean | tiger | dragon | rabbit | green |
#   space | egypt | ant | frankenstein | bird
NUXT_PUBLIC_SITE=lucky

# Full public URL of this site (used for sitemap.xml / robots.txt at build time)
NUXT_PUBLIC_SITE_URL=http://localhost:3000
# Exact browser-facing hosts accepted by Nitro (comma-separated, ports explicit).
NUXT_ALLOWED_HOSTS=localhost:3000

# Backend REST API base URL, including /api. SERVER-ONLY — read by the Nitro
# proxy at server/routes/api/[...path].ts and never shipped to the browser.
API_HOST_URL=http://localhost:4000/api

# Backend WebSocket origin, without /ws. SERVER-ONLY — read by
# server/plugins/ws-proxy.ts and never shipped to the browser.
WEBSOCKET_HOST_URL=ws://localhost:4000

# Node server port (read by Nitro on boot)
PORT=3000

# Redis (OPTIONAL) — shared SSR cache for public, user-independent fetches
# (menu, custom scripts, etc.) and the anonymous full-page cache. SERVER-ONLY.
# Point these at the SAME Redis the backend uses so the cache is shared and
# survives restarts. If REDIS_HOST is unset, the SSR cache transparently falls
# back to an in-process cache (per container, lost on restart).
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Anonymous full-page SSR cache (OPTIONAL, off by default). When "true",
# logged-out page renders are cached in Redis and reused; requests carrying a
# bn.session cookie always bypass it. See server/plugins/anon-page-cache.ts.
NUXT_ENABLE_ANON_PAGE_CACHE=false
# How long a cached anonymous page stays fresh, in milliseconds. Default 60000.
NUXT_ANON_PAGE_CACHE_TTL_MS=60000

# Sentry error monitoring (OPTIONAL — leave NUXT_PUBLIC_SENTRY_DSN empty to disable).
# The public DSN is shipped to the browser (expected for Sentry).
NUXT_PUBLIC_SENTRY_DSN=
# Source-map upload at build time (server-only — build machine / CI only).
# Build still succeeds when these are unset; the upload step is just skipped.
NUXT_PUBLIC_SENTRY_ORG=
NUXT_PUBLIC_SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# Theme Editor preview — origin(s) of the admin panel that embeds this site in
# an iframe for live theme preview. Comma-separated for multiple origins.
# Example: https://admin.example.com
# Leave blank in production if the admin panel and user site share the same origin.
NUXT_PUBLIC_ADMIN_PREVIEW_ORIGIN=
